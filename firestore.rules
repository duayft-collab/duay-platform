rules_version = '2';

// ════════════════════════════════════════════════════════════
// V194f — Duay Platform Firestore Rules
// 2026-05-07 · K02 server-side validation uyumlu
// 
// Pre-V194f snapshot: firestore.rules.console-snapshot.20260507
// 
// Yetki hiyerarşisi: super_admin → admin → manager → user
// 
// duay_company/master/* = organization-level master data
//   - read: tüm auth'lu kullanıcılar
//   - write: role-based (anayasa = super_admin only)
// ════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers: role lookup ────────────────────────────
    function getUserRole() {
      return get(/databases/$(database)/documents/duay_tenant_default/users/$(request.auth.uid)).data.role;
    }
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() && (getUserRole() == 'admin' || getUserRole() == 'super_admin');
    }
    function isSuperAdmin() {
      return isAuth() && getUserRole() == 'super_admin';
    }

    // ─── Tenant data (mevcut, korundu) ───────────────────
    match /duay_tenant_default/{document=**} {
      allow read, write: if isAuth();
    }

    // ─── duay_company/master (V194d + V194e) ────────────
    match /duay_company/master/anayasa_content {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }
    match /duay_company/master/anayasa_versions/list/{versionId} {
      allow read, write: if isSuperAdmin();
    }
    match /duay_company/master/sirket_data {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /duay_company/master/iban_data {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /duay_company/master/sartlar {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /duay_company/master/_audit_log/{entryId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }
    match /duay_company/{document=**} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Mevcut public-disabled paths (korundu) ──────────
    match /ihracat_uploads/{doc} {
      allow read, write: if isAuth();
    }
    match /ihracat_teklifler/{doc} {
      allow read, write: if isAuth();
    }
    match /ihracat_teklif_davetler/{doc} {
      allow read, write: if isAuth();
    }
  }
}
